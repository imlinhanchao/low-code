{
  "name": "@low-code/element-plus",
  "version": "1.0.0",
  "type": "module",
  "description": "Element Plus component definitions for the low-code designer/renderer",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "tsdown --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "element-plus": ">=2.0.0",
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "element-plus": "^2.13.5",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5"
  }
}
