{
  "name": "lc-ep",
  "version": "0.0.11",
  "type": "module",
  "description": "Element Plus component definitions for the low code designer/renderer",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./*": "./dist/*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lowcode",
    "designer",
    "renderer",
    "vue",
    "form",
    "form-builder",
    "element-plus"
  ],
  "author": {
    "name": "Hancel.Lin",
    "email": "imlinhanchao@foxmail.com",
    "url": "https://github.com/imlinhanchao"
  },
  "bugs": {
    "url": "https://github.com/imlinhanchao/low-code/issues"
  },
  "homepage": "https://github.com/imlinhanchao/low-code/tree/master/packages/element-plus#readme",
  "license": "MIT",
  "peerDependencies": {
    "element-plus": ">=2.1.0",
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "element-plus": "^2.13.5",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5"
  }
}
