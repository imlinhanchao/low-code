{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "./dist",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "lc-vue3": ["../../src/index.ts"]
    }
  },
  "include": ["src/**/*", "env.d.ts", "typings/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "tsdown.config.ts"]
}
