{
  "name": "lc-vue3",
  "version": "0.1.2",
  "description": "Configurable low code designer and renderer based on Vue 3",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./*": "./dist/*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "docs:dev": "vitepress dev --host ./docs",
    "docs:build": "vitepress build ./docs",
    "dev": "vite --host",
    "demo:build": "vite build --outDir docs/.vitepress/dist/demo",
    "build": "tsdown",
    "page:build": "npm run docs:build && npm run demo:build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lowcode",
    "designer",
    "renderer",
    "vue",
    "form",
    "form-builder"
  ],
  "bugs": {
    "url": "https://github.com/imlinhanchao/low-code/issues"
  },
  "homepage": "https://github.com/imlinhanchao/low-code#readme",
  "author": {
    "name": "Hancel.Lin",
    "email": "imlinhanchao@foxmail.com",
    "url": "https://github.com/imlinhanchao"
  },
  "license": "MIT",
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@low-code/element-plus": "*",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "element-plus": "^2.13.5",
    "less": "^4.5.1",
    "rollup-plugin-dts": "^6.4.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "unplugin-vue": "^7.1.1",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-pagefind": "^0.4.19",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0"
  },
  "release": {
    "branches": [
      "master"
    ]
  }
}
