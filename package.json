{
  "name": "low-code",
  "version": "0.0.1",
  "description": "Configurable low-code designer and renderer based on Vue 3",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "tsdown && vue-tsc --declaration --emitDeclarationOnly --outDir dist"
  },
  "keywords": [
    "low-code",
    "designer",
    "renderer",
    "vue",
    "form"
  ],
  "bugs": {
    "url": "https://github.com/imlinhanchao/low-code/issues"
  },
  "homepage": "https://github.com/imlinhanchao/low-code#readme",
  "author": {
    "name": "Hancel.Lin",
    "email": "imlinhanchao@foxmail.com",
    "url": "https://github.com/imlinhanchao"
  },  
  "license": "MIT",
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@low-code/element-plus": "*",
    "element-plus": "^2.13.5",
    "less": "^4.5.1",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0"
  },
  "release": {
    "branches": [
      "master"
    ]
  }
}
